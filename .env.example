# Railway Deployment Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Telegram Bot Configuration
# ============================================
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# ============================================
# OPTIONAL - API Keys
# ============================================

# AcoustID for Music Identification (free signup)
# https://acoustid.org/new-application
ACOUSTID_API_KEY=

# Google Gemini for SEO/Hashtag Generation (free)
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI for ChatGPT features
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude for Triple-AI consensus
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# MiniMax Agent API
MINIMAX_API_KEY=

# Replicate for Voice Cloning (free tier available)
# https://replicate.com
REPLICATE_API_TOKEN=
